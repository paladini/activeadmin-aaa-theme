source "https://rubygems.org"

# Specify dependencies via the gemspec file
gemspec

group :development, :test do
  gem "rspec-rails"
  gem "capybara"
  gem "sqlite3"
  gem "puma"
  gem "sassc-rails" # Needed to compile SCSS assets in the asset pipeline
  gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
  gem "devise"
end
